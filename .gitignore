# === 全域忽略 (Global Ignores) ===
__pycache__/
*.py[cod]
*$py.class
.DS_Store
Thumbs.db
*.bak
*.bat
node.txt
ecosystem.config.js

# === 敏感資訊 (Secrets) ===
.env*
*.env*
backend/*.env*
frontend/*.env*
frontend/certificates/*

# === 編輯器與工具 (IDE & AI Tools) ===
.vscode/
.cursor/
.cursor_git_history_*
.idea/

# === 後端特定 (Backend Specific) ===
backend/thumb_cache/
backend/.thumb_cache/
backend/static/adjust/*
backend/node_modules/

# 忽略 AI 模型檔 (大檔案不進 Git)
backend/models/*
# 如果你想保留 models 資料夾，可以取消下面這行的註解
# !backend/models/.gitkeep

# 忽略後端產生的所有暫存圖檔
backend/**/*.jpg
backend/**/*.png

# === 前端特定 (Frontend Specific) ===
node_modules/
frontend/node_modules/
.next/
out/
build/
frontend/dist/
frontend/build/
frontend/.next/
frontend/public/old-system-screenshot.png